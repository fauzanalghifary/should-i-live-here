{
  "name": "web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "prettier:check": "prettier --check \"*.{html,js,json,ts}\" \"src/**/*.{css,ts,tsx}\"",
    "prettier:fix": "prettier --write \"*.{html,js,json,ts}\" \"src/**/*.{css,ts,tsx}\""
  },
  "dependencies": {
    "@headlessui/react": "^2.2.10",
    "@tanstack/react-query": "^5.101.0",
    "maplibre-gl": "^5.24.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@eslint/js": "latest",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@types/geojson": "^7946.0.16",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "prettier": "latest",
    "tailwindcss": "^4.3.1",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
